{
  "id": "wendl",
  "name": "Wendl",
  "description": "Budget-aware companion for the Wendl gateway (or any LiteLLM-compatible proxy): /limits and /stats show per-key caps, spend, and savings at zero token cost.",
  "version": "0.1.0",
  "commandAliases": [
    { "name": "limits", "kind": "runtime-slash", "cliCommand": "limits" },
    { "name": "stats", "kind": "runtime-slash", "cliCommand": "stats" },
    { "name": "wendl", "kind": "runtime-slash", "cliCommand": "wendl" }
  ],
  "activation": {
    "onStartup": false,
    "onCommands": ["limits", "stats", "wendl"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "litellmBaseUrl": { "type": "string", "default": "http://localhost:4000" },
      "litellmMasterKey": { "type": "string" },
      "globalCapUsd": { "type": "number" },
      "keys": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["team", "ops"]
      }
    },
    "required": ["litellmMasterKey"]
  },
  "uiHints": {
    "litellmMasterKey": { "label": "Router master key (Wendl gateway / LiteLLM)", "placeholder": "sk-...", "sensitive": true },
    "litellmBaseUrl": { "label": "Router base URL (Wendl gateway / LiteLLM)", "placeholder": "http://localhost:4000" },
    "globalCapUsd": { "label": "Global safety cap (USD / 30d)", "placeholder": "300" }
  }
}
